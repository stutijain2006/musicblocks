{
    "name": "musicblocks",
    "version": "3.4.1",
    "main": "electron-main.js",
    "description": "A musical microworld",
    "repository": {
        "url": "https://github.com/sugarlabs/musicblocks.git"
    },
    "license": "AGPL-3.0 License",
    "bugs": {
        "url": "https://github.com/sugarlabs/musicblocks/issues"
    },
    "amd": {},
    "scripts": {
        "lint": "eslint js/ planet/js/",
        "lint:staged": "lint-staged",
        "prepare": "husky",
        "serve": "http-server -a 127.0.0.1 -p 3000 --gzip --brotli",
        "serve:dev": "http-server -a 127.0.0.1 -p 3000 -c-1",
        "start": "node index.js",
        "dev": "cross-env NODE_ENV=development nodemon index.js",
        "prod": "cross-env NODE_ENV=production node index.js",
        "test": "jest",
        "cypress:run": "cypress run",
        "electron": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/eslint-parser": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "cross-env": "^7.0.3",
        "cypress": "^15.9.0",
        "electron": "^40.8.5",
        "electron-builder": "26.8.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "fake-indexeddb": "6.2.5",
        "gulp": "^5.0.1",
        "gulp-babel": "^8.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-prettier": "^3.0.0",
        "gulp-uglify": "^3.0.2",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "lint-staged": "^15.5.2",
        "nodemon": "^3.1.9",
        "prettier": "^3.6.2"
    },
    "dependencies": {
        "@tonejs/midi": "^2.0.28",
        "autoprefixer": "^10.4.16",
        "compression": "^1.8.1",
        "cssnano": "^6.0.1",
        "express": "^4.21.2",
        "gulp-concat": "^2.6.1",
        "gulp-postcss": "^9.0.1",
        "gulp-replace": "^1.0.0",
        "gulp-sass": "^5.1.0",
        "gulp-sourcemaps": "^2.6.5",
        "http-server": "^14.1.1",
        "i18next": "^25.3.2",
        "i18next-http-backend": "^3.0.2",
        "tone": "^15.1.22",
        "lodash": "^4.17.21",
        "qs": "^6.14.2",
        "svgo": "^4.0.1",
        "yaml": "^2.8.3",
        "path-to-regexp": "0.1.13"
    },
    "build": {
        "appId": "com.musicblocks.app",
        "productName": "Music Blocks",
        "mac": {
            "category": "public.app-category.music",
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "overrides": {
        "tar": "^7.5.10",
        "ajv": "^6.14.0",
        "@isaacs/brace-expansion": "^5.0.1",
        "brace-expansion": "^1.1.12",
        "immutable": "^5.1.5",
        "@gulp-sourcemaps/identity-map": {
            "postcss": "^8.4.31"
        },
        "async": "3.2.6",
        "portfinder": "1.0.32",

        "express": {
            "path-to-regexp": "0.1.13",
            "qs": "6.14.2"
        },
        "body-parser": {
            "qs": "6.14.2"
        }
    },
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --max-warnings=0 --fix",
            "prettier --write"
        ]
    }
}